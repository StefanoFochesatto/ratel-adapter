{
  "scripts": {
    "format": "find . -name '*.c' -o -name '*.h' | grep -E '^(./src/|./include/|./examples/|./tests/)' | xargs clang-format -i",
    "format:check": "find . -name '*.c' -o -name '*.h' | grep -E '^(./src/|./include/|./examples/|./tests/)' | xargs clang-format --dry-run --Werror"
  },
  "devDependencies": {}
}
